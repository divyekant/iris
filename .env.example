PORT=3000
DATABASE_URL=./data/iris.db
OLLAMA_URL=http://localhost:11434
MEMORIES_URL=http://localhost:8900
PUBLIC_URL=http://localhost:3000

# Gmail OAuth2 (optional — needed for Gmail accounts)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Outlook OAuth2 (optional — needed for Outlook accounts)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# Memories API key (optional — for Memories MCP authentication)
MEMORIES_API_KEY=

# Optional: Argon2 PHC hash for the web UI password gate
# IRIS_AUTH_PASSWORD_HASH=

# Optional: 32-byte base64 or 64-character hex key for encrypting stored secrets at rest
# IRIS_SECRETS_KEY=

# Session token file (optional — writes the session token to a file for Docker/script integration)
# SESSION_TOKEN_FILE=/app/data/session-token
